# Copy to tests/integration/.env and adjust if needed.
# cp tests/integration/env.example tests/integration/.env

# Service base URLs (services started via make run-*)
IDENTITY_SERVICE_URL=http://localhost:8081
COMPANY_SERVICE_URL=http://localhost:8082
TRANSPORT_ORDER_SERVICE_URL=http://localhost:8083
RFX_SERVICE_URL=http://localhost:8084
SHIPMENT_SERVICE_URL=http://localhost:8085
DOCUMENT_SERVICE_URL=http://localhost:8086
BILLING_REGISTER_SERVICE_URL=http://localhost:8087

# PostgreSQL (for tenant bootstrap via docker exec)
POSTGRES_CONTAINER=freight_postgres
POSTGRES_USER=freight
POSTGRES_PASSWORD=freight_password
POSTGRES_DB=freight_platform

# Test tenant (created via SQL if not exists)
TENANT_CODE=test-tenant
TENANT_NAME=Test Tenant

# Optional suffix for unique TEST-* numbers on re-runs (defaults to timestamp)
# SMOKE_RUN_ID=20260617120000
